{
  "name": "governed-excel-formula-modules",
  "version": "0.1.0",
  "private": true,
  "description": "Public template for governed Excel formula modules and Office.js setup tooling.",
  "scripts": {
    "addin:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/start_addin_smoke_test.ps1",
    "addin:server": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/start_addin_dev_server.ps1",
    "addin:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/stop_addin_smoke_test.ps1",
    "dev-server": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/start_addin_dev_server.ps1"
  },
  "devDependencies": {
    "office-addin-debugging": "^6.0.3"
  }
}
